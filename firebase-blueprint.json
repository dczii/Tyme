{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and workspace settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "picture": { "type": "string" },
        "workdayTargetHours": { "type": "number" },
        "logoStyle": { "type": "string", "enum": ["classic", "minimalist", "hourglass"] }
      },
      "required": ["email", "name"]
    },
    "Project": {
      "title": "Project",
      "description": "A client project that time entries can be catalogued under",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "client": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "userId", "name", "color"]
    },
    "Tag": {
      "title": "Tag",
      "description": "Customizable categorization tags for time entries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "userId", "name"]
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "A singular time log tracked by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "description": { "type": "string" },
        "projectId": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["id", "userId", "description", "date", "startTime", "endTime", "durationMinutes"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Workspace profile for each registered Gmail user"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects associated with the user's workspace"
    },
    "/users/{userId}/tags/{tagId}": {
      "schema": "Tag",
      "description": "Tags defined on the user's workspace"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "TimeEntry",
      "description": "Individual time entries logged within the user's workspace"
    }
  }
}
